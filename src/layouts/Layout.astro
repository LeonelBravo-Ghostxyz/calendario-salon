---
// src/layouts/Layout.astro
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Calendario de Reservas</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	/* Le decimos al navegador que toda la app es oscura para que los inputs y popups nativos se adapten */
	:root {
		color-scheme: dark;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
		/* Fondo oscuro base */
		background-color: #0f172a; 
		/* Un gradiente sutil radial para que el efecto cristal (glassmorphism) resalte mucho más */
		background-image: radial-gradient(at top left, #1e293b, #020617);
		background-attachment: fixed;
		color: #f8fafc;
		font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
	}
</style>