<div class="calendar-panel glass-container">
  <header class="calendar-header">
    <button id="prevMonth" class="nav-btn">&lt;</button>
    
    <div style="display:flex; align-items:center; gap:0.8rem;">
      <h2 id="monthYearTitle" class="calendar-title" title="Buscar mes">Cargando...</h2>
      <button id="btnUnlock" class="nav-btn" style="background:transparent; border: 1px solid rgba(255,255,255,0.2); padding: 0.3rem 0.6rem;" title="Ingresar como Administrador">🔒</button>
    </div>
    
    <button id="nextMonth" class="nav-btn">&gt;</button>
  </header>

  <div class="calendar-grid days-of-week">
    <span>Dom</span><span>Lun</span><span>Mar</span><span>Mié</span><span>Jue</span><span>Vie</span><span>Sáb</span>
  </div>
  
  <div id="calendarGrid" class="calendar-grid days-grid"></div>
</div>

<div id="toastOverlay" class="toast-overlay hidden">
  <div class="glass-popover" id="toastBox">
    </div>
</div>

<style>
  .glass-container {
    background: var(--glass-bg); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border); border-radius: 16px; padding: 1.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1); color: var(--text-color); max-width: 900px; margin: 0 auto;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .calendar-title { cursor: pointer; margin: 0; padding: 0.5rem 1rem; border-radius: 8px; }
  .calendar-title:hover { background-color: var(--glass-hover); }
  .nav-btn { background: var(--glass-bg); border: none; color: var(--text-color); padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; }
  .nav-btn:hover { background: var(--glass-hover); }
  .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; }
  .days-of-week span { text-align: center; font-weight: 600; font-size: 0.9rem; padding-bottom: 0.5rem; }

  :global(.day-cell) {
    min-height: 110px; padding: 8px; border-radius: 8px; background-color: var(--glass-cell);
    border: 1px solid var(--glass-border); transition: background-color 0.3s ease;
    display: flex; flex-direction: column; gap: 4px;
    min-width: 0; 
  }
  :global(.day-cell:not(.empty-cell)) { cursor: pointer; }
  :global(.day-cell:not(.empty-cell):hover) { background-color: var(--glass-hover); }
  :global(.empty-cell) { background: transparent; border: none; }
  :global(.day-number) { font-size: 0.85rem; opacity: 0.8; align-self: flex-end; }
  
  :global(.event-badge) {
    font-size: 0.75rem; background-color: rgba(59, 130, 246, 0.4); border: 1px solid rgba(59, 130, 246, 0.8);
    padding: 4px 6px; border-radius: 4px; color: white; 
    
    /* Reglas estrictas para truncar el texto */
    white-space: nowrap; 
    overflow: hidden; 
    text-overflow: ellipsis;
    width: 100%; 
    box-sizing: border-box;
    display: block; /* Forzamos a que respete el 100% del ancho en vez de comportarse como texto libre */
  }
  :global(.badge-mediodia) { background-color: rgba(245, 158, 11, 0.4); border-color: rgba(245, 158, 11, 0.8); }

  /* --- Toast & Popover Styles --- */
  .toast-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(3px);
    display: flex; justify-content: center; align-items: center;
    z-index: 1000; transition: opacity 0.2s ease;
  }
  .toast-overlay.hidden { opacity: 0; pointer-events: none; }
  .glass-popover {
    background: var(--glass-popover); border: 1px solid var(--glass-border);
    border-radius: 12px; padding: 1.5rem; width: 100%; max-width: 320px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3); color: var(--text-color); font-family: system-ui;
  }
  :global(.form-input) {
    width: 100%; padding: 0.7rem; border-radius: 6px; border: 1px solid var(--glass-border);
    background: var(--input-bg); color: var(--text-color); margin-bottom: 0.8rem; box-sizing: border-box;
  }
  :global(.toast-flex) { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  :global(.toast-close) { background: none; border: none; color: var(--text-muted); font-size: 1.2rem; cursor: pointer; }
  :global(.toast-close:hover) { color: var(--text-color); }
  :global(.toast-btn-row) { display: flex; gap: 0.5rem; margin-top: 1rem; }

  /* --- Diseño Responsivo para Móviles --- */
  @media (max-width: 768px) {
    .glass-container { padding: 0.5rem; border-radius: 12px; }
    .calendar-header { margin-bottom: 1rem; }
    .calendar-title { font-size: 1.1rem; padding: 0.4rem; }
    .nav-btn { padding: 0.4rem 0.8rem; font-size: 1rem; }
    .calendar-grid { gap: 3px; }
    .days-of-week span { font-size: 0.75rem; overflow: hidden; text-overflow: ellipsis; }
    :global(.day-cell) { min-height: 85px; padding: 4px; border-radius: 6px; }
    :global(.day-number) { font-size: 0.75rem; }
    :global(.event-badge) { font-size: 0.65rem; padding: 2px 4px; border-radius: 3px; }
  }
</style>

<script>
  let adminPass: string | null = sessionStorage.getItem('salon_admin_pass') || null;
  let isAdmin: boolean = !!adminPass;

  const grid = document.getElementById('calendarGrid') as HTMLElement;
  const title = document.getElementById('monthYearTitle') as HTMLElement;
  const toastOverlay = document.getElementById('toastOverlay') as HTMLElement;
  const toastBox = document.getElementById('toastBox') as HTMLElement;
  
  let currentDate = new Date();
  let eventos: any[] = [];
  let fechaSeleccionada: string = "";
  let notaSeleccionada: any = null;

  const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];

  async function fetchEventos() {
    try {
      const res = await fetch('/api/eventos');
      if (res.ok) {
        eventos = await res.json();
      }
    } catch (error) { 
      console.error(error); 
    } finally {
      renderCalendar();
    }
  }

  function renderCalendar() {
    grid.innerHTML = '';
    const year = currentDate.getFullYear();
    const month = currentDate.getMonth();
    title.textContent = `${meses[month]} ${year}`;

    const primerDia = new Date(year, month, 1).getDay();
    const diasEnMes = new Date(year, month + 1, 0).getDate();

    for (let i = 0; i < primerDia; i++) {
      const empty = document.createElement('div');
      empty.className = 'day-cell empty-cell';
      grid.appendChild(empty);
    }

    for (let i = 1; i <= diasEnMes; i++) {
      const cell = document.createElement('div');
      cell.className = 'day-cell';
      
      const numeroDia = document.createElement('span');
      numeroDia.className = 'day-number';
      numeroDia.textContent = String(i);
      cell.appendChild(numeroDia);

      const mesF = String(month + 1).padStart(2, '0');
      const diaF = String(i).padStart(2, '0');
      const fechaActualString = `${year}-${mesF}-${diaF}`;

      const notasDelDia = eventos.filter(e => e.fecha === fechaActualString);
      
      notasDelDia.sort((a, b) => a.turno === 'Mediodía' ? -1 : 1);

      notasDelDia.forEach(nota => {
        const badge = document.createElement('div');
        badge.className = `event-badge ${nota.turno === 'Mediodía' ? 'badge-mediodia' : ''}`;
        badge.textContent = `${nota.turno.substring(0,1)}: ${nota.cliente}`; 
        
        if (isAdmin) {
          badge.addEventListener('click', (e) => {
            e.stopPropagation(); 
            (window as any).mostrarToastDatos(nota);
          });
        }
        cell.appendChild(badge);
      });

      if (isAdmin) {
        cell.addEventListener('click', () => {
          if (notasDelDia.length >= 2) {
            alert('Este día ya tiene sus dos turnos (Mediodía y Noche) ocupados.');
          } else {
            (window as any).mostrarToastVacio(fechaActualString);
          }
        });
      }
      grid.appendChild(cell);
    }
  }

  // --- Funciones Globales del Toast ---
  (window as any).cerrarToast = function() {
    toastOverlay.classList.add('hidden');
  };

  (window as any).mostrarToastVacio = function(fecha: string) {
    fechaSeleccionada = fecha;
    toastBox.innerHTML = `
      <div class="toast-flex">
        <h3 style="margin:0;">Día: ${fecha}</h3>
        <button class="toast-close" onclick="cerrarToast()">✖</button>
      </div>
      <p style="color:var(--text-muted); font-size:0.9rem;">No hay eventos seleccionados.</p>
      <button class="nav-btn" style="width:100%; background:#10b981; margin-top:0.5rem;" onclick="mostrarFormulario(false)">Añadir Reserva</button>
    `;
    toastOverlay.classList.remove('hidden');
  };

  (window as any).mostrarToastDatos = function(nota: any) {
    notaSeleccionada = nota;

    toastBox.innerHTML = `
      <div class="toast-flex">
        <h3 style="margin:0;">${nota.turno}</h3>
        <button class="toast-close" onclick="cerrarToast()">✖</button>
      </div>
      <div style="font-size:0.9rem; color:var(--text-color); line-height: 1.6;">
        <p><strong>Cliente:</strong> ${nota.cliente}</p>
        <p><strong>Teléfono:</strong> ${nota.telefono || '-'}</p>
        <p><strong>Registro:</strong> ${nota.creado_en}</p>
        <p><strong>Notas:</strong> <br/>${nota.notas || '-'}</p>
      </div>
      <div class="toast-btn-row">
        <button class="nav-btn" style="flex:1; background:rgba(239, 68, 68, 0.8);" 
                onclick="eliminarReserva('${nota._id}')">Eliminar</button>
        
        <button class="nav-btn" style="flex:1; background:rgba(59, 130, 246, 0.8);" 
                onclick="mostrarFormulario(true)">Editar</button>
      </div>
    `;
    toastOverlay.classList.remove('hidden');
  };

  (window as any).mostrarFormulario = function(isEdit: boolean) {
    const defaultTurno = isEdit ? notaSeleccionada.turno : 'Mediodía';
    
    toastBox.innerHTML = `
      <div class="toast-flex">
        <h3 style="margin:0;">${isEdit ? 'Editar' : 'Nueva'} Reserva</h3>
        <button class="toast-close" onclick="cerrarToast()">✖</button>
      </div>
      <form id="reservaForm">
        <input type="text" id="f_cliente" class="form-input" placeholder="Nombre del Cliente" value="${isEdit ? notaSeleccionada.cliente : ''}" required autocomplete="off" />

        <select id="f_socio" class="form-input">
          <option value="false" ${!isEdit || !notaSeleccionada.socio ? 'selected' : ''}>Cliente Regular</option>
          <option value="true" ${isEdit && notaSeleccionada.socio ? 'selected' : ''}>Socio</option>
        </select>

        <select id="f_turno" class="form-input">
          <option value="Mediodía" ${defaultTurno === 'Mediodía' ? 'selected' : ''}>Mediodía</option>
          <option value="Noche" ${defaultTurno === 'Noche' ? 'selected' : ''}>Noche</option>
        </select>
        
        <input type="text" id="f_telefono" class="form-input" placeholder="Teléfono (Opcional)" value="${isEdit ? notaSeleccionada.telefono : ''}" autocomplete="off" />
        <textarea id="f_notas" class="form-input" placeholder="Añadir notas..." rows="3">${isEdit ? notaSeleccionada.notas : ''}</textarea>
        
        <button type="submit" class="nav-btn" style="width:100%; background:#10b981;">Guardar Reserva</button>
      </form>
    `;

    document.getElementById('reservaForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const payload = {
        fecha: isEdit ? notaSeleccionada.fecha : fechaSeleccionada,
        cliente: (document.getElementById('f_cliente') as HTMLInputElement).value,
        socio: (document.getElementById('f_socio') as HTMLSelectElement).value === 'true',
        turno: (document.getElementById('f_turno') as HTMLSelectElement).value,
        telefono: (document.getElementById('f_telefono') as HTMLInputElement).value,
        notas: (document.getElementById('f_notas') as HTMLTextAreaElement).value,
        creado_en: isEdit ? notaSeleccionada.creado_en : new Date().toLocaleString('es-AR')
      };

      try {
        const url = isEdit ? `/api/eventos/${notaSeleccionada._id}` : '/api/eventos';
        const method = isEdit ? 'PUT' : 'POST';
        
        const res = await fetch(url, { 
          method, 
          headers: { 
            'Content-Type': 'application/json',
            'x-admin-password': adminPass || ''
          }, 
          body: JSON.stringify(payload) 
        });

        const result = await res.json();

        if (!res.ok) {
          alert("Error de servidor: " + (result.error || 'No autorizado'));
          return;
        }
        
        (window as any).cerrarToast();
        fetchEventos(); 
        notaSeleccionada = null; 
      } catch (err) {
        alert("Error de red al intentar guardar la reserva.");
      }
    });
  };

  (window as any).eliminarReserva = async function(id: string) {
    if (!id) {
      alert("Error: No se encontró el ID de la reserva.");
      return;
    }

    if (confirm('¿Seguro que deseas eliminar el registro de esta fecha?')) {
      try {
        const res = await fetch(`/api/eventos/${id}`, { 
          method: 'DELETE',
          headers: {
            'x-admin-password': adminPass || ''
          }
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || "No se pudo eliminar");
        }

        (window as any).cerrarToast();
        fetchEventos(); 
      } catch (err: any) {
        alert("Error al eliminar: " + err.message);
      }
    }
  };

// --- Lógica del Candado ---
  const btnUnlock = document.getElementById('btnUnlock') as HTMLElement;
  btnUnlock.addEventListener('click', async () => {
    if (isAdmin) {
      // Si ya es admin y toca el candado, cerramos sesión
      sessionStorage.removeItem('salon_admin_pass');
      window.location.reload();
    } else {
      // Si no es admin, pedimos la clave
      const pass = prompt("Ingresa la clave de administrador:");
      
      if (pass) {
        try {
          btnUnlock.textContent = '⏳'; // Pequeño feedback visual de carga
          
          // Le preguntamos al servidor si la clave es correcta
          const res = await fetch('/api/verify', {
            method: 'POST',
            headers: { 'x-admin-password': pass }
          });

          if (res.ok) {
            // ¡Clave correcta! La guardamos y recargamos
            sessionStorage.setItem('salon_admin_pass', pass);
            window.location.reload(); 
          } else {
            // Clave incorrecta
            alert("Contraseña incorrecta. Acceso denegado.");
            btnUnlock.textContent = '🔒'; // Volvemos al candado cerrado
          }
        } catch (error) {
          alert("Error al verificar la contraseña.");
          btnUnlock.textContent = '🔒';
        }
      }
    }
  });

  if (isAdmin) {
    btnUnlock.textContent = '🔓';
    btnUnlock.style.background = 'rgba(16, 185, 129, 0.3)';
    btnUnlock.title = "Cerrar sesión";
  }

  // --- Controles de Meses ---
  const prevMonthBtn = document.getElementById('prevMonth') as HTMLElement;
  const nextMonthBtn = document.getElementById('nextMonth') as HTMLElement;

  prevMonthBtn.addEventListener('click', () => { 
    currentDate.setMonth(currentDate.getMonth() - 1); 
    renderCalendar(); 
  });
  
  nextMonthBtn.addEventListener('click', () => { 
    currentDate.setMonth(currentDate.getMonth() + 1); 
    renderCalendar(); 
  });
  
  title.addEventListener('click', () => {
    const input = prompt("Buscar (MM-YYYY):", `${String(currentDate.getMonth() + 1).padStart(2, '0')}-${currentDate.getFullYear()}`);
    if (input && input.includes('-')) {
      const [m, y] = input.split('-');
      currentDate.setMonth(parseInt(m, 10) - 1);
      currentDate.setFullYear(parseInt(y, 10));
      renderCalendar();
    }
  });

  // Carga inicial
  fetchEventos();
</script>